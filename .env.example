# Copie ce fichier en .env (il est ignoré par git)
# Objectif: utiliser des identifiants "TEST" en local pour ne pas consommer les crédits PROD.

# --- Auth JWT (Netlify functions) ---
# Une string longue et random (ex: 32+ chars)
AUTH_SECRET=change_me_long_random

# --- Supabase (TEST) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_test_service_role_key

# --- Cloudinary (TEST) ---
CLOUDINARY_CLOUD_NAME=your_test_cloud_name
CLOUDINARY_API_KEY=your_test_api_key
CLOUDINARY_API_SECRET=your_test_api_secret

# Upload preset (unsigned/signed preset côté Cloudinary)
CLOUDINARY_UPLOAD_PRESET=your_test_upload_preset
